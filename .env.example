# Copy to .env and fill values locally. Never commit real keys.
TOSSINVEST_API_KEY=
TOSSINVEST_SECRET_KEY=
TOSSINVEST_ACCOUNT=

# Defaults are intentionally centralized and overrideable while validating docs.
TOSSINVEST_BASE_URL=https://openapi.tossinvest.com
TOSSINVEST_TOKEN_PATH=/oauth2/token

# Trading guardrails.
MAX_ORDER_AMOUNT_KRW=10000
MAX_DAILY_ORDER_COUNT=3
DRY_RUN=true
